#!/bin/sh
# Why: コミット前にバグ予防チェックを走らせる。失敗したらコミット中止。
#   husky 等の追加依存なしで動かすため、git config core.hooksPath = .githooks
#   で有効化する（README.md / docs/ に手順を記載）。
#
# 実行内容:
#   1. node --check で構文エラー検出（fast, 1s 未満）
#   2. ESLint で no-redeclare/no-undef 等のバグパターン検出
#   3. CLAUDE.md カスタム lint で error severity 違反検出
#   4. npm test で 566 ユニットテスト
#
# 全部失敗なしで進む。1 つでも error なら commit 中止。

set -e

echo "▶ pre-commit: syntax check..."
errors=0
for f in src/*.js; do
  if ! node --check "$f" 2>/dev/null; then
    echo "  ✗ syntax error in $f"
    errors=$((errors + 1))
  fi
done
if [ "$errors" -gt 0 ]; then
  echo "✗ pre-commit aborted: $errors syntax error(s)"
  exit 1
fi
echo "  ✓ syntax OK ($(ls src/*.js | wc -l | tr -d ' ') files)"

echo "▶ pre-commit: CLAUDE.md custom lint (error only)..."
if ! node scripts/lint.js --severity error; then
  echo "✗ pre-commit aborted: CLAUDE.md rule violation (ERROR)"
  exit 1
fi

echo "▶ pre-commit: ESLint..."
if ! npx eslint --quiet src/*.js; then
  echo "✗ pre-commit aborted: ESLint errors"
  exit 1
fi
echo "  ✓ ESLint OK (no errors)"

echo "▶ pre-commit: unit tests..."
if ! npm test --silent > /tmp/pre-commit-tests.log 2>&1; then
  tail -20 /tmp/pre-commit-tests.log
  echo "✗ pre-commit aborted: tests failed"
  exit 1
fi
echo "  ✓ all tests passed"

echo "✓ pre-commit OK"
