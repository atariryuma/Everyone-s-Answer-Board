{
  "name": "everyone-s-answer-board",
  "version": "1.0.0",
  "description": "A collaborative answer board using Google Apps Script (GAS + clasp workflow)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "git config core.hooksPath .githooks || true",
    "pull": "clasp pull",
    "push": "clasp push",
    "open": "clasp open",
    "logs": "clasp logs",
    "deploy": "clasp deploy",
    "deploy:prod": "node scripts/deploy-prod.js",
    "deploy:list": "node scripts/deploy-list.js",
    "push:open": "node scripts/env-switch.js open npx clasp push --force",
    "deploy:open": "node scripts/env-switch.js open node scripts/deploy-prod.js --env open",
    "deploy:all": "npm run deploy:prod && npm run deploy:open",
    "api": "node scripts/admin-api.js",
    "api:open": "node scripts/admin-api.js --env open",
    "logs:cloud": "node scripts/logs.js",
    "logs:open": "node scripts/logs.js --env open",
    "logs:tail": "node scripts/logs.js --tail",
    "logs:summary": "node scripts/logs.js --summary --hours 3 --limit 500 --severity WARNING",
    "logs:errors": "node scripts/logs.js --summary --hours 24 --limit 1000 --severity ERROR",
    "check": "npm test && node scripts/admin-api.js systemDiagnosis",
    "test": "node --test tests/*.test.cjs",
    "test:coverage": "node scripts/test-coverage.js",
    "lint": "node scripts/lint.js",
    "lint:errors": "node scripts/lint.js --severity error",
    "lint:eslint": "eslint src/*.js",
    "theme:audit": "node scripts/theme-audit.js",
    "theme:contrast": "node scripts/theme-contrast.js",
    "theme:check": "node scripts/theme-audit.js && node scripts/theme-contrast.js",
    "theme:verify": "node scripts/theme-verify.js",
    "theme:matrix": "node scripts/theme-matrix.js",
    "theme:uncovered": "node scripts/theme-matrix.js --uncovered",
    "theme:tokenize": "node scripts/theme-tokenize.js",
    "theme:tokenize:dry": "node scripts/theme-tokenize.js --dry-run",
    "theme:pair": "node scripts/theme-pair-tailwind.js",
    "theme:pair:dry": "node scripts/theme-pair-tailwind.js --dry-run",
    "theme:perfect": "node scripts/theme-perfect.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atariryuma/Everyone-s-Answer-Board.git"
  },
  "keywords": [
    "gas",
    "google-apps-script",
    "clasp"
  ],
  "author": "Ryuma Atari",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/atariryuma/Everyone-s-Answer-Board/issues"
  },
  "homepage": "https://github.com/atariryuma/Everyone-s-Answer-Board#readme",
  "devDependencies": {
    "@google/clasp": "^3.1.3",
    "eslint": "^10.3.0",
    "globals": "^17.6.0"
  }
}
